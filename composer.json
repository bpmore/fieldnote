{
    "name": "bpmore/fieldnote",
    "description": "A minimalist markdown blogging platform. Modernized and hardened fork.",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "altorouter/altorouter": "^2.0",
        "erusev/parsedown": "~1.7.4",
        "erusev/parsedown-extra": "^0.8",
        "lbuchs/webauthn": "^2.2",
        "rakibtg/sleekdb": "^2.14"
    },
    "suggest": {
        "ext-zip": "Required for the markdown export/import feature (/admin/export, /admin/import)"
    },
    "autoload": {
        "psr-4": {
            "Fieldnote\\": "src/"
        },
        "files": [
            "src/i18n.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
